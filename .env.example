# Eolite – Environment Variables
# Copy to .env and fill in values

# ── Logging ─────────────────────────────────────────────────
# NODE_ENV=development  → dev mode (colored, human-readable logs, debug level)
# NODE_ENV=production   → prod mode (safe logs, JSON format, info level)
# LOG_LEVEL=debug       → all levels visible (default in dev)
# LOG_LEVEL=info        → info/warn/error only (default in prod)
# LOG_LEVEL=warn        → warn/error only
# LOG_LEVEL=error       → error only
# LOG_LEVEL=fatal       → fatal only

# ── Database ─────────────────────────────────────────────────────────────────
# DB_PROVIDER=sqlite    → local development (default when not set)
# DB_PROVIDER=postgres  → production (Railway / Neon)

# --- SQLite (local dev) ---
DB_PROVIDER=sqlite
SQLITE_PATH=./backend/eolite.db

# --- PostgreSQL (production) ---
# DB_PROVIDER=postgres
# DATABASE_URL=postgresql://user:password@host:5432/eolite

# Server
PORT=3002
JWT_SECRET=change-this-to-a-long-random-string

# Email (default: mock – saves to console + backend/logs/emails/)
EMAIL_MODE=mock
EMAIL_FROM=noreply@eolite.cz
ADMIN_EMAIL=admin@eolite.cz

# SMTP (only needed if EMAIL_MODE=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
